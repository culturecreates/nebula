<turbo-frame id="sparqls">
  <h3>SPARQLs <%= button_to "↻", github_sparqls_refresh_path, method: :post, class: "btn btn-sm btn-outline-secondary" %></h3>
  <ul>
    <% @sparqls.each do |sparql| %>
      <li>
        <a href="/query/show?sparql=<%= sparql["download_url"] %>" target="_top">
          <%= humanize_url(sparql["download_url"]) %>
        </a>
        (<a href="<%= sparql["html_url"] %>" target="_blank">edit</a>)
      </li>
    <% end %>
  </ul>
</turbo-frame>
