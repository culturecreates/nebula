<% content_for(:title) { "Artsdata SKOS Vocabularies" } %>
<% content_for(:head) do %>
  <script src="https://cdn.jsdelivr.net/npm/d3@7" nonce="<%= content_security_policy_nonce %>"></script>
<% end %>


  <div class="vocabularies-page" data-controller="vocabularies" data-vocabularies-lang-value="en">
    <div class="text-center py-3">
      <h1 class="h4" data-vocabularies-target="title">Artsdata SKOS Controlled Vocabularies</h1>
      <p class="text-muted small mb-0" data-vocabularies-target="subtitle">Click a circle to zoom in. Click outside to zoom out.</p>
    </div>
    <div id="loading" class="text-center py-5" data-vocabularies-target="loading">
      <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
      </div>
      <p class="mt-2 text-muted">Fetching vocabularies from Artsdata...</p>
    </div>
    <div id="chart" data-vocabularies-target="chart"></div>
    <div id="tooltip" data-vocabularies-target="tooltip" class="vocab-tooltip"></div>
  </div>
