<% content_for(:title) { "Artsdata SKOS Vocabularies" } %>
<% content_for(:head) do %>
  <script src="https://cdn.jsdelivr.net/npm/d3@7" nonce="<%= content_security_policy_nonce %>"></script>
<% end %>


  <div class="vocabularies-page" data-controller="vocabularies" data-vocabularies-lang-value="en" data-vocabularies-sparql-endpoint-value="<%= Rails.configuration.graph_api_endpoint %>">
    <div class="text-center py-3">
      <div class="mb-2">
        <div class="btn-group btn-group-sm" role="group" aria-label="Language selection">
          <button type="button" 
                  class="btn btn-outline-primary active" 
                  data-vocabularies-target="enBtn" 
                  data-action="click->vocabularies#switchLang"
                  data-lang="en">EN</button>
          <button type="button" 
                  class="btn btn-outline-primary" 
                  data-vocabularies-target="frBtn" 
                  data-action="click->vocabularies#switchLang"
                  data-lang="fr">FR</button>
        </div>
      </div>
      <h1 class="h4" data-vocabularies-target="title">Artsdata SKOS Controlled Vocabularies</h1>
      <p class="text-muted small mb-0" data-vocabularies-target="subtitle">Click a circle to zoom in. Click outside to zoom out.</p>
    </div>
    <div id="loading" class="text-center py-5" data-vocabularies-target="loading">
      <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
      </div>
      <p class="mt-2 text-muted">Fetching vocabularies from Artsdata...</p>
    </div>
    <div id="chart" data-vocabularies-target="chart"></div>
    <div id="tooltip" data-vocabularies-target="tooltip" class="vocab-tooltip"></div>
  </div>
