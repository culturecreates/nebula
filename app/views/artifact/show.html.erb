<div class="container">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Artifacts", artifact_index_path %></li>
      <li class="breadcrumb-item active" aria-current="page"><%= @artifact.artifact_id %></li>
    </ol>
  </nav>

  <h1 class="text-truncate">
    <%= @artifact.name ||= @artifact.artifact_id %>
  </h1>
  <%= render partial: "shared/clipboard", locals: { uri: @artifact.uri } %>

  <div class="mt-3">
    <p>
      <%= @artifact.description %>
    </p>
  </div>
  <div class="d-flex gap-2 mb-4">
    <%= form_with url: push_latest_artifact_index_path, method: :post, local: true, html: { data: { controller: "confirm", action: "submit->confirm#confirm", confirm: "Load the latest artifact into an Artsdata data feed graph?" } } do |form| %>
      <%= form.hidden_field :artifactUri, value: @artifact.uri %>
      <%= form.submit "Load Artifact",
                  class: "btn btn-secondary",
                  data: {
                    disable_with: "Loading...",
                  } %>
    <% end %>

    <%= form_with url: artifact_path, method: :delete, local: true, html: { data: { controller: "confirm", action: "submit->confirm#confirm", confirm: "Delete artifact metadata for #{@artifact.artifact_id}? This will also delete the corresponding graph from the Artsdata Knowledge Graph." } } do |form| %>
      <%= form.hidden_field :artifactUri, value: @artifact.uri %>
      <%= form.hidden_field :graph, value: @artifact.graph %>
      <%= form.submit "Delete",
                  class: "btn btn-danger",
                  data: {
                    disable_with: "Deleting...",
                  } %>
    <% end %>

  </div>
  <!-- Toggle Auto-Minting Button -->
  <div class="card mb-4">
    <div class="card-body">
      <h3 class="card-title">Auto-Minting</h3>
      <p>
        Automatically mint events with Artsdata URIs every time this artifact is loaded into an Artsdata data feed graph.
      </p>
      <% automint_toggle_id = "auto-minting-toggle" %>
      <div class="d-flex flex-wrap align-items-center gap-3">
        <p class="mb-0">
          Current status:
          <% if @automint_status %>
            <strong>enabled &#10003;</strong>
          <% else %>
            <strong>disabled</strong>
          <% end %>
        </p>
        <%= form_with url: toggle_auto_minting_artifact_index_path, method: :post, local: true, html: { class: "mb-0", data: { turbo: "false" } } do |form| %>
          <%= form.hidden_field :graph, value: @artifact.graph %>
          <%= form.hidden_field :new_boolean, value: !@automint_status %>
          <%= check_box_tag :auto_minting_toggle, "1", @automint_status,
              class: "btn-check",
              id: automint_toggle_id,
              autocomplete: "off",
              onchange: "this.form.requestSubmit ? this.form.requestSubmit() : this.form.submit();" %>
          <%= label_tag automint_toggle_id,
              "Auto-Minting #{@automint_status ? 'enabled' : 'disabled'}",
              class: "btn btn-outline-secondary" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <h3 class="card-title">Graph Metadata</h3>
      <p>Metadata for the Artsdata data feed graph used for describing and ranking sources.</p>
      <p>
        <%= link_to "View Data Feed", entity_path(uri: @artifact.graph), class: "btn btn-outline-secondary btn-sm" %>
      </p>
      <%= form_with url: update_graph_metadata_artifact_index_path, method: :post, local: true, html: { data: { turbo: "false" } } do |form| %>
        <%= form.hidden_field :graph, value: @artifact.graph %>

        <div class="mb-3">
          <%= form.label :graph_name, "Name", class: "form-label" %>
          <%= text_field_tag :graph_name, @graph_metadata[:name], class: "form-control"%>
        </div>

        <div class="mb-3">
          <%= form.label :maintainer, "Maintainer", class: "form-label" %>
          <%= url_field_tag :maintainer, @graph_metadata[:maintainer], class: "form-control", placeholder: "website of the organization maintaining the data" %>
        </div>

        <div class="mb-3">
          <%= form.label :rating_value, "Rating Value", class: "form-label" %>
          <%= text_field_tag :rating_value, @graph_metadata[:rating_value], class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= form.label :rating_explanation, "Rating Explanation", class: "form-label" %>
          <%= text_area_tag :rating_explanation, @graph_metadata[:rating_explanation], class: "form-control", rows: 3 %>
        </div>

        <div class="d-flex gap-2">
          <%= form.submit "Save Metadata", class: "btn btn-secondary", data: { disable_with: "Saving..." } %>
          <%= button_tag "Delete Metadata",
            type: "submit",
            name: "delete_metadata",
            value: "true",
            class: "btn btn-danger",
            data: { disable_with: "Deleting..." } %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <h3 class="card-title">Artifact Versions</h3>
      <p>Versions of artifacts that can be loaded into Artsdata data feed graphs.</p>
      <% if @artifact_versions.present? %>
        <% total_versions = @artifact_versions.count %>
        <% displayed_versions = @artifact_versions.first(10) %>
        <p><strong>Total versions: <%= total_versions %></strong></p>
        <table class="table table-sm">
          <thead>
            <tr>
              <th>Date</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% displayed_versions.each do |version| %>
              <% version_uri = "#{@artifact.uri}/#{version.version}#Dataset" %>
              <tr>
                <td><%= version.version %></td>
                <td>
                  <%= form_with url: push_version_artifact_index_path, method: :post, local: true, html: { data: { controller: "confirm", action: "submit->confirm#confirm", confirm: "Load artifact version #{version.version} into an Artsdata data feed graph?" } } do |form| %>
                    <%= form.hidden_field :artifactUri, value: @artifact.uri %>
                    <%= form.hidden_field :artifactVersionUri, value: version_uri %>
                    <%= form.submit "Load",
                                class: "btn btn-secondary btn-sm",
                                data: {
                                  disable_with: "Loading...",
                                } %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
        <% if total_versions > 10 %>
          <p><%= link_to "View all #{total_versions} versions", entity_path(uri: @artifact.uri) %></p>
        <% end %>
      <% else %>
        <p class="text-muted">No versions available yet. Check back later.</p>
      <% end %>
    </div>
  </div>
</div>
