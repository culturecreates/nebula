PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX dcterms: <http://purl.org/dc/terms/>

SELECT ?dataset_uri ?version
WHERE {
  <GRAPH_URI> prov:wasDerivedFrom/foaf:primaryTopic ?dataset_uri .
  OPTIONAL { ?dataset_uri dcterms:hasVersion ?version . }
}
LIMIT 1
